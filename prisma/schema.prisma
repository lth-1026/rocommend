datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String           @id @default(cuid())
  email           String?          @unique
  emailVerified   DateTime?
  name            String?
  image           String?
  role            Role             @default(USER)
  preferences     Json?            // { onboardingVersion: number, inferredProfile: object }
  createdAt       DateTime         @default(now())
  accounts        Account[]
  sessions        Session[]
  onboarding      Onboarding?
  ratings         Rating[]
  bookmarks       Bookmark[]
  recommendations Recommendation[]
  feedbacks       Feedback[]
}

model Onboarding {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version     Int      @default(3)
  q1          String[] // 브루잉방법 (복수)
  q2          String   // 구매성향
  q3          String[] // 선호가격대 (복수, "크게 신경 안 써요" 상호 배타)
  q4          String   // 구매빈도 (FIRST_TIME이면 q5 스킵)
  q5          String[] // 선호로스터리 ID (q4=FIRST_TIME이면 빈 배열)
  completedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Roastery {
  id                    String           @id @default(cuid())
  name                  String
  description           String?
  address               String?
  priceRange            PriceRange
  decaf                 Boolean          @default(false)
  imageUrl              String?
  website               String?          // deprecated — RoasteryChannel로 마이그레이션 예정
  isOnboardingCandidate Boolean          @default(false) // Q5 목록 노출 여부
  createdAt             DateTime         @default(now())
  tags                  RoasteryTag[]
  ratings               Rating[]
  bookmarks             Bookmark[]
  beans                 Bean[]
  recommendations       Recommendation[]
  channels              RoasteryChannel[]
  featuredIn            FeaturedSectionRoastery[]

  @@index([priceRange])
  @@index([decaf])
  @@index([name])
}

model Tag {
  id         String        @id @default(cuid())
  name       String
  category   TagCategory
  roasteries RoasteryTag[]

  @@unique([name, category])
  @@index([category])
}

model RoasteryTag {
  roasteryId String
  tagId      String
  isPrimary  Boolean  @default(false)
  roastery   Roastery @relation(fields: [roasteryId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([roasteryId, tagId])
  @@index([tagId])
}

model Bean {
  id            String             @id @default(cuid())
  roasteryId    String
  name          String
  origins       String[]           // 원산지 (복수)
  roastingLevel String             // LIGHT | MEDIUM | MEDIUM_DARK | DARK
  decaf         Boolean            @default(false)
  cupNotes      String[]           // e.g. ["자몽", "카카오", "흑설탕"]
  imageUrl      String?
  createdAt     DateTime           @default(now())
  roastery      Roastery           @relation(fields: [roasteryId], references: [id], onDelete: Cascade)
  channelPrices BeanChannelPrice[]

  @@index([roasteryId])
}

model ChannelDefinition {
  id       String            @id @default(cuid())
  key      String            @unique  // "naver" | "website" | "cm29" | "unspecialty" | ...
  label    String            // "네이버 스마트스토어" | "자사몰" | ...
  logoUrl  String?
  order    Int               @default(0) // 가격 없는 채널의 fallback 정렬
  channels RoasteryChannel[]
}

model RoasteryChannel {
  id         String            @id @default(cuid())
  roasteryId String
  channelKey String
  url        String
  createdAt  DateTime          @default(now())
  roastery   Roastery          @relation(fields: [roasteryId], references: [id], onDelete: Cascade)
  definition ChannelDefinition @relation(fields: [channelKey], references: [key])
  beanPrices BeanChannelPrice[]

  @@unique([roasteryId, channelKey])
  @@index([roasteryId])
}

model BeanChannelPrice {
  beanId    String
  channelId String
  price     Int              // 원 단위 (e.g. 16000)
  bean      Bean            @relation(fields: [beanId], references: [id], onDelete: Cascade)
  channel   RoasteryChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([beanId, channelId])
}

model Rating {
  id         String   @id @default(cuid())
  userId     String
  roasteryId String
  score      Int      @db.SmallInt // 1–5. 애플리케이션 레이어에서도 검증 필요
  comment    String?
  source     String?  // "onboarding" | null (직접 평가)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roastery   Roastery @relation(fields: [roasteryId], references: [id], onDelete: Cascade)

  @@unique([userId, roasteryId])
  @@index([userId])     // "내 평가 목록" 조회
  @@index([roasteryId]) // "이 로스터리의 평가" 조회 + CF 계산
}

model Recommendation {
  id         String   @id @default(cuid())
  userId     String
  roasteryId String
  score      Float
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roastery   Roastery @relation(fields: [roasteryId], references: [id], onDelete: Cascade)

  @@unique([userId, roasteryId])
  @@index([userId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  roasteryId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roastery   Roastery @relation(fields: [roasteryId], references: [id], onDelete: Cascade)

  @@unique([userId, roasteryId])
  @@index([userId])
  @@index([roasteryId])
}

model FeaturedSection {
  id         String                    @id @default(cuid())
  title      String
  type       SectionType               @default(CUSTOM)
  order      Int                       @default(0)
  isActive   Boolean                   @default(true)
  roasteries FeaturedSectionRoastery[]
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
}

model FeaturedSectionRoastery {
  sectionId  String
  roasteryId String
  order      Int             @default(0)
  section    FeaturedSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  roastery   Roastery        @relation(fields: [roasteryId], references: [id], onDelete: Cascade)

  @@id([sectionId, roasteryId])
  @@index([roasteryId])
}

model EventLog {
  id        String   @id @default(cuid())
  userId    String?
  event     String   // rating_submitted | recommendation_clicked | purchase_link_clicked | onboarding_completed
  payload   Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([createdAt])
}

// ── NextAuth 필수 모델 ──────────────────────────────

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String  // "google" | "kakao" | "naver"
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_at Int?    // Kakao/Naver refresh token 만료 추적용
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// NextAuth database 세션 전략 필수 모델.
// 세션 강제 만료(로그아웃, 계정 정지)가 필요해 database 전략 유지.
// Vercel 서버리스에서 연결 수 초과 방지를 위해 Prisma Accelerate 필수.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime // 90일 후 만료
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum SectionType {
  CF_NEW    // "새로운 로스터리" — 협업 필터링 신규 추천
  CF_REPEAT // "또 사고 싶은 로스터리" — CF 재구매 추천
  POPULAR   // "실시간 인기 로스터리"
  CUSTOM    // 관리자가 직접 큐레이션한 섹션
}

enum PriceRange {
  LOW  // 200g 기준 20,000원 미만
  MID  // 20,000–35,000원
  HIGH // 35,000원 초과
}

enum TagCategory {
  REGION         // 한국 광역자치단체 (서울, 부산 등)
  CHARACTERISTIC // 로스터리 특성 (싱글오리진, 블렌드 등)
}

enum Role {
  USER
  ADMIN
}

model Feedback {
  id        String         @id @default(cuid())
  content   String
  category  String?
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    FeedbackStatus @default(PENDING)
  createdAt DateTime       @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum FeedbackStatus {
  PENDING
  READ
}
