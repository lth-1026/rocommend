generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String           @id @default(cuid())
  email                String?          @unique
  name                 String?
  nickname             String?  @unique
  image                String?
  createdAt            DateTime         @default(now())
  preferences          Json?
  emailVerified        DateTime?
  role                 Role             @default(USER)
  receiveFeedbackEmail Boolean          @default(false)
  accounts             Account[]
  bookmarks            Bookmark[]
  feedbacks            Feedback[]
  roasteryRequests     RoasteryRequest[]
  onboarding           Onboarding?
  ratings              Rating[]
  ratingReports        RatingReport[]
  recommendations      Recommendation[]
  sessions             Session[]
}

model Onboarding {
  id          String   @id @default(cuid())
  userId      String   @unique
  q1          String[]
  q2          String
  q3          String[]
  q4          String
  q5          String[]
  completedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  version     Int      @default(3)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Roastery {
  id                    String                    @id @default(cuid())
  name                  String
  description           String?
  priceRange            PriceRange
  decaf                 Boolean                   @default(false)
  imageUrl              String?
  website               String?
  createdAt             DateTime                  @default(now())
  isOnboardingCandidate Boolean                   @default(false)
  address               String?
  closedAt              DateTime?
  hidden                Boolean                   @default(false)
  deletedAt             DateTime?
  beans                 Bean[]
  bookmarks             Bookmark[]
  featuredIn            FeaturedSectionRoastery[]
  locations             RoasteryLocation[]
  ratings               Rating[]
  recommendations       Recommendation[]
  channels              RoasteryChannel[]
  tags                  RoasteryTag[]

  @@index([priceRange])
  @@index([decaf])
  @@index([name])
  @@index([deletedAt])
}

model RoasteryLocation {
  id         String   @id @default(cuid())
  roasteryId String
  address    String
  lat        Float?
  lng        Float?
  isPrimary  Boolean  @default(false)
  roastery   Roastery @relation(fields: [roasteryId], references: [id], onDelete: Cascade)

  @@index([roasteryId])
}

model Tag {
  id         String        @id @default(cuid())
  name       String
  category   TagCategory
  roasteries RoasteryTag[]

  @@unique([name, category])
  @@index([category])
}

model RoasteryTag {
  roasteryId String
  tagId      String
  isPrimary  Boolean  @default(false)
  roastery   Roastery @relation(fields: [roasteryId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([roasteryId, tagId])
  @@index([tagId])
}

model Bean {
  id            String             @id @default(cuid())
  roasteryId    String
  name          String
  origins       String[]
  roastingLevel String
  decaf         Boolean            @default(false)
  cupNotes      String[]
  imageUrl      String?
  createdAt     DateTime           @default(now())
  hidden        Boolean            @default(false)
  deletedAt     DateTime?
  roastery      Roastery           @relation(fields: [roasteryId], references: [id], onDelete: Cascade)
  channelPrices BeanChannelPrice[]

  @@index([roasteryId])
  @@index([deletedAt])
}

model ChannelDefinition {
  id       String            @id @default(cuid())
  key      String            @unique
  label    String
  logoUrl  String?
  order    Int               @default(0)
  channels RoasteryChannel[]
}

model RoasteryChannel {
  id         String             @id @default(cuid())
  roasteryId String
  channelKey String
  url        String
  createdAt  DateTime           @default(now())
  beanPrices BeanChannelPrice[]
  definition ChannelDefinition  @relation(fields: [channelKey], references: [key])
  roastery   Roastery           @relation(fields: [roasteryId], references: [id], onDelete: Cascade)

  @@unique([roasteryId, channelKey])
  @@index([roasteryId])
}

model BeanChannelPrice {
  beanId                   String
  channelId                String
  price                    Int
  sourceUrl                String?
  sizeGrams                Int?
  bean                     Bean                       @relation(fields: [beanId], references: [id], onDelete: Cascade)
  channel                  RoasteryChannel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  BeanChannelPriceSnapshot BeanChannelPriceSnapshot[]

  @@id([beanId, channelId])
}

model Rating {
  id         String         @id @default(cuid())
  userId     String
  roasteryId String
  score      Int            @db.SmallInt
  comment    String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  source     String?
  roastery   Roastery       @relation(fields: [roasteryId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports    RatingReport[]

  @@unique([userId, roasteryId])
  @@index([userId])
  @@index([roasteryId])
}

model RatingReport {
  id        String             @id @default(cuid())
  ratingId  String
  userId    String
  reason    RatingReportReason
  createdAt DateTime           @default(now())
  rating    Rating             @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ratingId, userId])
  @@index([ratingId])
  @@index([userId])
}

model Recommendation {
  id         String   @id @default(cuid())
  userId     String
  roasteryId String
  score      Float
  updatedAt  DateTime @updatedAt
  roastery   Roastery @relation(fields: [roasteryId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roasteryId])
  @@index([userId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  roasteryId String
  createdAt  DateTime @default(now())
  roastery   Roastery @relation(fields: [roasteryId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roasteryId])
  @@index([userId])
  @@index([roasteryId])
}

model FeaturedSection {
  id         String                    @id @default(cuid())
  title      String
  order      Int                       @default(0)
  isActive   Boolean                   @default(true)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  type       SectionType               @default(CUSTOM)
  roasteries FeaturedSectionRoastery[]
}

model FeaturedSectionRoastery {
  sectionId  String
  roasteryId String
  order      Int             @default(0)
  roastery   Roastery        @relation(fields: [roasteryId], references: [id], onDelete: Cascade)
  section    FeaturedSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([sectionId, roasteryId])
  @@index([roasteryId])
}

model EventLog {
  id        String   @id @default(cuid())
  userId    String?
  event     String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([createdAt])
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  refresh_token_expires_at Int?
  id_token                 String?
  scope                    String?
  session_state            String?
  token_type               String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Feedback {
  id        String         @id @default(cuid())
  content   String
  category  String?
  userId    String
  status    FeedbackStatus @default(PENDING)
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model BeanChannelPriceSnapshot {
  id               String           @id
  beanId           String
  channelId        String
  price            Int
  snappedAt        DateTime         @default(now())
  BeanChannelPrice BeanChannelPrice @relation(fields: [beanId, channelId], references: [beanId, channelId], onDelete: Cascade)

  @@index([beanId, channelId])
  @@index([snappedAt])
}

enum SectionType {
  CF_NEW
  CF_REPEAT
  POPULAR
  CUSTOM
}

enum PriceRange {
  LOW
  MID
  HIGH
}

enum TagCategory {
  REGION
  CHARACTERISTIC
}

enum Role {
  USER
  ADMIN
}

enum FeedbackStatus {
  PENDING
  READ
}

model RoasteryRequest {
  id        String                @id @default(cuid())
  name      String
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    RoasteryRequestStatus @default(PENDING)
  createdAt DateTime              @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum RoasteryRequestStatus {
  PENDING
  READ
}

enum RatingReportReason {
  SPAM
  INAPPROPRIATE
  OTHER
}
